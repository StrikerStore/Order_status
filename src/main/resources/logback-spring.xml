<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- So logging.level.* in application.properties / env (e.g. Railway) still applies -->
    <springProperty name="ROOT_LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>
    <springProperty name="APP_LOG_LEVEL" source="logging.level.com.shipway.ordertracking" defaultValue="INFO"/>
    
    <property name="LOG_FILE" value="${LOG_FILE:-logs/application.log}"/>
    <property name="LOG_FILE_MAX_SIZE" value="5MB"/>
    <property name="LOG_FILE_MAX_HISTORY" value="5"/>
    
    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN:-%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n}</pattern>
        </encoder>
    </appender>
    
    <!-- File Appender with Rolling Policy -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Rollover daily and when file size reaches 5MB -->
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.zip</fileNamePattern>
            <!-- Maximum file size before rolling -->
            <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
            <!-- Keep maximum 5 zip files (oldest will be deleted) -->
            <maxHistory>${LOG_FILE_MAX_HISTORY}</maxHistory>
            <!-- Total size cap for all log files -->
            <totalSizeCap>50MB</totalSizeCap>
            <!-- Clean history on startup -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>
    
    <!--
      App logs: own appenders + additivity=false so they still print even if root is WARN/ERROR
      (some hosts set LOG_LEVEL=error or similar).
    -->
    <logger name="com.shipway.ordertracking" level="${APP_LOG_LEVEL:-INFO}" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Root Logger (framework + third-party) -->
    <root level="${ROOT_LOG_LEVEL:-INFO}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <logger name="org.springframework.web" level="INFO"/>
</configuration>
